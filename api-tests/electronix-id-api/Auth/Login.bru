meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{runEmail}}",
    "password": "{{userPassword}}"
  }
}

vars:post-response {
  accessToken: res.body.access_token
  refreshToken: res.body.refresh_token
}

assert {
  res.status: eq 200
  res.body.access_token: isDefined
}

docs {
  Logs in with the email Register created this run. To run Login alone, set runEmail in the Local environment to a known user.
}
