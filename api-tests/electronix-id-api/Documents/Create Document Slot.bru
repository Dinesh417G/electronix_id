meta {
  name: Create Document Slot
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/machines/{{machineId}}/documents
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "category": "plc_program",
    "name": "Main PLC Program",
    "storage_kind": "file"
  }
}

vars:post-response {
  documentId: res.body.id
}

assert {
  res.status: eq 201
  res.body.id: isDefined
}

docs {
  Creates a versioned document slot of storage_kind=file. Captures documentId.
}
