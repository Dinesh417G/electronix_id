meta {
  name: Upload Version 1 (file)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/documents/{{documentId}}/versions
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  file: @file(samples/sample-program.txt)
  change_note: initial upload
}

assert {
  res.status: eq 201
}

docs {
  Multipart upload -> creates version 1. The file path is relative to this collection folder.
}
