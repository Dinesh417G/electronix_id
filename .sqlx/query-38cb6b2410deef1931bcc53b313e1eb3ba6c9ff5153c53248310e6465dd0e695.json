  "query": "\n                    SELECT id, machine_id, category, name, storage_kind, current_version_no,\n                           created_by, created_at, updated_at\n                    FROM documents\n                    WHERE machine_id = ?\n                      AND machine_id IN (SELECT id FROM machines WHERE organization_id = ?)\n                    ORDER BY created_at ASC, id ASC\n                    ",
