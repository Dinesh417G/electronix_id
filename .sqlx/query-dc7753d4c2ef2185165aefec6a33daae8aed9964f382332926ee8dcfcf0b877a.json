  "query": "\n            SELECT d.current_version_no AS `current_version_no!: i32`,\n                   d.machine_id AS `machine_id!`\n            FROM documents d\n            JOIN machines m ON m.id = d.machine_id\n            WHERE d.id = ? AND m.organization_id = ?\n            FOR UPDATE\n            ",
